# Local development configuration. Production non-secret configuration starts
# from .env.production.example and secrets are synchronized from GCP Secret Manager.
APP_BASE_URL=http://localhost:3000

DATABASE_URL=postgres://agentern:change-me@db:5432/agentern
DATABASE_POOL_SIZE=5
VALKEY_URL=redis://valkey:6379

# Generate independent high-entropy values for both secrets.
TOKEN_PEPPER=replace-with-at-least-32-random-bytes
ADMIN_CLI_SECRET=replace-with-an-independent-admin-secret

TRUST_PROXY=false
MCP_VERBOSE=false
ENFORCE_PRODUCTION_CONFIG=false
PROXY_SHARED_SECRET=replace-with-an-independent-32-byte-proxy-secret
METRICS_BEARER_TOKEN=replace-with-an-independent-32-byte-metrics-secret

# Local identity defaults.
AGENTERN_DOMAIN=agentern.com
ACME_EMAIL=ops@agentern.com
LEGAL_ENTITY_NAME=replace-with-your-registered-legal-entity
SUPPORT_EMAIL=support@agentern.com
SECURITY_EMAIL=security@agentern.com

# pgBackRest S3-compatible encrypted off-site repository. These PGBACKREST_*
# variables are consumed by pgBackRest directly inside the database container.
PGBACKREST_REPO1_S3_BUCKET=
PGBACKREST_REPO1_S3_ENDPOINT=
PGBACKREST_REPO1_S3_REGION=
PGBACKREST_REPO1_S3_KEY=replace-me
PGBACKREST_REPO1_S3_KEY_SECRET=replace-me
PGBACKREST_REPO1_CIPHER_TYPE=aes-256-cbc
PGBACKREST_REPO1_CIPHER_PASS=replace-with-a-strong-independent-passphrase

POSTGRES_DB=agentern
POSTGRES_USER=agentern
POSTGRES_PASSWORD=change-me
