# Store the completed file as the latest version of the agentern-env GCP
# Secret Manager secret. All credential values live in separate secrets.
APP_BASE_URL=https://agentern.com
DATABASE_POOL_SIZE=5
VALKEY_URL=redis://valkey:6379

TRUST_PROXY=true
MCP_VERBOSE=false
ENFORCE_PRODUCTION_CONFIG=true

AGENTERN_DOMAIN=agentern.com
ACME_EMAIL=ops@agentern.com
LEGAL_ENTITY_NAME=replace-with-your-registered-legal-entity
SUPPORT_EMAIL=support@agentern.com
SECURITY_EMAIL=security@agentern.com

PGBACKREST_REPO1_S3_BUCKET=agentern-backups
PGBACKREST_REPO1_S3_ENDPOINT=s3.example.com
PGBACKREST_REPO1_S3_REGION=us-east-1
PGBACKREST_REPO1_CIPHER_TYPE=aes-256-cbc

POSTGRES_DB=agentern
POSTGRES_USER=agentern
